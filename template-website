Instrustions to build a file to build a image for a container in which we will run a website.

  FROM amazonlinux:latest
  RUN yum install httpd zip unzip -y
  WORKDIR /var/www/html
  ADD https://templated.live/hielo/download/hielo.zip /var/www/html
  RUN unzip hielo.zip && rm -f hielo.zip
  EXPOSE 80
  CMD ["/usr/sbin/httpd", "-D", "FOREGROUND"]   

